<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/edtMaLinhKien"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Mã linh kiện"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtTenLinhKien"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tên linh kiện"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtSoLuong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Số lượng tồn"
        android:inputType="number"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtGiaNhap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Giá nhập (VNĐ)"
        android:inputType="numberDecimal"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerLoai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>